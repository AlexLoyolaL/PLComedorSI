rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }

    match /roles/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /settings_day/{day} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // en prod: limitar a Supervisor
    }


    match /sales/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn(); // en producción: limitar a Administrativo
      allow delete: if false;
    }

    match /dayAgg/{day} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // en producción: limitar a Administrativo
    }

    match /membersDayIndex/{key} {
      allow read, write: if isSignedIn(); // en producción: limitar write a Administrativo
    }
  }
}
